                                ; R0 = R0 * R1, where R0 and R1 are unsigned 8-bit values
                                ; Destroys R1, R4
0x6F80                          qs_mpy8:    PROC
6F80   0084                     	    MOVR    R0,	     R4      ;   6
6F81   02F9 6D81                	    ADDI    #QSQR8_TBL.mid, R1      ;   8
6F83   00CC                     	    ADDR    R1,	     R4      ;   6   a + b
6F84   0101                     	    SUBR    R0,	     R1      ;   6   a - b
6F85   02A0                     @@ok:       MVI@    R4,	     R0      ;   8
6F86   0308                     	    SUB@    R1,	     R0      ;   8
6F87   00AF                     	    JR      R5		      ;   7
                                					    ;----
                                					    ;  49
                                	    ENDP
                                	    

                                ; R1 = R0 * R1, where R0 and R1 are 16-bit values
                                ; destroys R0, R2, R3, R4, R5
0x6F88                          qs_mpy16:   PROC
6F88   0275                     	    PSHR    R5		  ;   9
                                				   
                                	    ; Unpack lo/hi
6F89   0082                     	    MOVR    R0,	 R2      ;   6   
6F8A   03B8 00FF                	    ANDI    #$FF,       R0      ;   8   R0 is lo(a)
6F8C   01C2                     	    XORR    R0,	 R2      ;   6   
6F8D   0042                     	    SWAP    R2		  ;   6   R2 is hi(a)

6F8E   008B                     	    MOVR    R1,	 R3      ;   6   R3 is orig 16-bit b
6F8F   03B9 00FF                	    ANDI    #$FF,       R1      ;   8   R1 is lo(b)
6F91   008D                     	    MOVR    R1,	 R5      ;   6   R5 is lo(b)
6F92   01CB                     	    XORR    R1,	 R3      ;   6   
6F93   0043                     	    SWAP    R3		  ;   6   R3 is hi(b)
                                					;----
                                					;  67
                                					
                                	    ; lo * lo		   
6F94   0084                     	    MOVR    R0,	 R4      ;   6   R4 is lo(a)
6F95   02F9 6D81                	    ADDI    #QSQR8_TBL.mid, R1  ;   8
6F97   00CC                     	    ADDR    R1,	 R4      ;   6   R4 = lo(a) + lo(b)
6F98   0101                     	    SUBR    R0,	 R1      ;   6   R1 = lo(a) - lo(b)
                                					
6F99   02A4                     @@pos_ll:   MVI@    R4,	 R4      ;   8   R4 = qstbl[lo(a)+lo(b)]
6F9A   030C                     	    SUB@    R1,	 R4      ;   8   R4 = lo(a)*lo(b)
                                					;----
                                					;  42
                                					;  67 (carried forward)
                                					;----
                                					; 109
                                				       
                                	    ; lo * hi		  
6F9B   0081                     	    MOVR    R0,	 R1      ;   6   R0 = R1 = lo(a)
6F9C   02FB 6D81                	    ADDI    #QSQR8_TBL.mid, R3  ;   8
6F9E   00D9                     	    ADDR    R3,	 R1      ;   6   R1 = hi(b) + lo(a)
6F9F   0103                     	    SUBR    R0,	 R3      ;   6   R3 = hi(b) - lo(a)
                                				       
6FA0   0289                     @@pos_lh:   MVI@    R1,	 R1      ;   8   R1 = qstbl[hi(b)-lo(a)]
6FA1   0319                     	    SUB@    R3,	 R1      ;   8   R1 = lo(a)*hi(b)
                                					;----
                                					;  42
                                					; 109 (carried forward)
                                					;----
                                					; 151
                                				       
                                	    ; hi * lo		  
6FA2   00A8                     	    MOVR    R5,	 R0      ;   6   R5 = R0 = lo(b)
6FA3   02FA 6D81                	    ADDI    #QSQR8_TBL.mid, R2  ;   8
6FA5   00D5                     	    ADDR    R2,	 R5      ;   6   R3 = hi(a) + lo(b)
6FA6   0102                     	    SUBR    R0,	 R2      ;   6   R2 = hi(a) - lo(b)
                                				       
6FA7   02E9                     @@pos_hl:   ADD@    R5,	 R1      ;   8   \_ R1 = lo(a)*hi(b)+hi(a)*lo(b)
6FA8   0311                     	    SUB@    R2,	 R1      ;   8   /
                                					;----
                                					;  42
                                					; 151 (carried forward)
                                					;----
                                					; 193
                                				       
6FA9   0041                     	    SWAP    R1		  ;   6   \_ shift upper product left 8
6FAA   03B9 FF00                	    ANDI    #$FF00,     R1      ;   8   /
6FAC   00E1                     	    ADDR    R4,	 R1      ;   6   final product
6FAD   02B7                     	    PULR    PC		  ;  12
                                					;----
                                					;  32
                                					; 193 (carried forward)
                                					;----
                                					; 225
                                	    ENDP

                                	ENDI

                                	IF intybasic_fastdiv

                                ; Fast unsigned division/remainder
                                ; Assembly code by Oscar Toledo G. Jul/10/2015
                                ; Released to public domain.

                                	; Ultrafast unsigned division/remainder operation
                                	; Entry: R0 = Dividend
                                	;	R1 = Divisor
                                	; Output: R0 = Quotient
                                	;	 R2 = Remainder
                                	; Worst case: 6 + 6 + 9 + 496 = 517 cycles
                                	; Best case: 6 + (6 + 7) * 16 = 214 cycles

                                uf_udiv16:	PROC
                                	CLRR R2		; 6
                                	SLLC R0,1	; 6
                                	BC @@1		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@2		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@3		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@4		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@5		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@6		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@7		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@8		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@9		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@10		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@11		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@12		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@13		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@14		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@15		; 7/9
                                	SLLC R0,1	; 6
                                	BC @@16		; 7/9
                                	JR R5

                                @@1:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@2:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@3:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@4:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@5:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@6:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@7:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@8:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@9:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@10:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@11:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@12:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@13:	RLC R2,1	; 6
                                	CMPR R1,R2	; 6
                                	BNC $+3		; 7/9
                                	SUBR R1,R2	; 6
                                	RLC R0,1	; 6
                                @@14:	RLC R2,1	; 6
