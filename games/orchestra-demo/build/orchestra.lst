61DE   0066                     	SLR R2,2
61DF   0066                     	SLR R2,2
61E0   03B8 007F                	ANDI #$007F,R0
61E2   01D0                     	XORR R2,R0
61E3   03C0 0342                	XOR _frame,R0
                                ;	_ROR
61E5   0070                     	RRC R0,1
61E6   0082                     	MOVR R0,R2
61E7   0066                     	SLR R2,2
61E8   0066                     	SLR R2,2
61E9   03BA 0800                	ANDI #$0800,R2
61EB   0066                     	SLR R2,2
61EC   0066                     	SLR R2,2
61ED   03B8 007F                	ANDI #$007F,R0
61EF   01D0                     	XORR R2,R0
61F0   03C0 0104                	XOR _rand,R0
                                ;	_ROR
61F2   0070                     	RRC R0,1
61F3   0082                     	MOVR R0,R2
61F4   0066                     	SLR R2,2
61F5   0066                     	SLR R2,2
61F6   03BA 0800                	ANDI #$0800,R2
61F8   0066                     	SLR R2,2
61F9   0066                     	SLR R2,2
61FA   03B8 007F                	ANDI #$007F,R0
61FC   01D0                     	XORR R2,R0
61FD   03F8 0009                	XORI #9,R0
