                                ;; ======================================================================== ;;
                                ;;  INTELLIVOICE DRIVER ROUTINES					    ;;
                                ;;  Written in 2002 by Joe Zbiciak <intvnut AT gmail.com>		   ;;
                                ;;  http://spatula-city.org/~im14u2c/intv/				  ;;
                                ;; ======================================================================== ;;

                                ;; ======================================================================== ;;
                                ;;  GLOBAL VARIABLES USED BY THESE ROUTINES				 ;;
                                ;;									  ;;
                                ;;  Note that some of these routines may use one or more global variables.  ;;
                                ;;  If you use these routines, you will need to allocate the appropriate    ;;
                                ;;  space in either 16-bit or 8-bit memory as appropriate.  Each global     ;;
                                ;;  variable is listed with the routines which use it and the required      ;;
                                ;;  memory width.							   ;;
                                ;;									  ;;
                                ;;  Example declarations for these routines are shown below, commented out. ;;
                                ;;  You should uncomment these and add them to your program to make use of  ;;
                                ;;  the routine that needs them.  Make sure to assign these variables to    ;;
                                ;;  locations that aren't used for anything else.			   ;;
                                ;; ======================================================================== ;;

                                			; Used by       Req'd Width     Description
                                			;-----------------------------------------------------
                                ;IV.QH      EQU $110    ; IV_xxx	8-bit	   Voice queue head
                                ;IV.QT      EQU $111    ; IV_xxx	8-bit	   Voice queue tail
                                ;IV.Q       EQU $112    ; IV_xxx	8-bit	   Voice queue  (8 bytes)
                                ;IV.FLEN    EQU $11A    ; IV_xxx	8-bit	   Length of FIFO data
                                ;IV.FPTR    EQU $320    ; IV_xxx	16-bit	  Current FIFO ptr.
                                ;IV.PPTR    EQU $321    ; IV_xxx	16-bit	  Current Phrase ptr.

                                ;; ======================================================================== ;;
                                ;;  MEMORY USAGE							    ;;
                                ;;									  ;;
                                ;;  These routines implement a queue of "pending phrases" that will be      ;;
                                ;;  played by the Intellivoice.  The user calls IV_PLAY to enqueue a	;;
                                ;;  phrase number.  Phrase numbers indicate either a RESROM sample or       ;;
                                ;;  a compiled in phrase to be spoken.				      ;;
                                ;;									  ;;
                                ;;  The user must compose an "IV_PHRASE_TBL", which is composed of	  ;;
                                ;;  pointers to phrases to be spoken.  Phrases are strings of pointers      ;;
                                ;;  and RESROM triggers, terminated by a NUL.			       ;;
                                ;;									  ;;
                                ;;  Phrase numbers 1 through 42 are RESROM samples.  Phrase numbers	 ;;
                                ;;  43 through 255 index into the IV_PHRASE_TBL.			    ;;
                                ;;									  ;;
                                ;;  SPECIAL NOTES							   ;;
                                ;;									  ;;
                                ;;  Bit 7 of IV.QH and IV.QT is used to denote whether the Intellivoice     ;;
                                ;;  is present.  If Intellivoice is present, this bit is clear.	     ;;
                                ;;									  ;;
                                ;;  Bit 6 of IV.QT is used to denote that we still need to do an ALD $00    ;;
                                ;;  for FIFO'd voice data.						  ;;
                                ;; ======================================================================== ;;
                                	    

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_INIT     Initialize the Intellivoice			     ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      15-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_INIT						      ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0      0 if Intellivoice found, -1 if not.			 ;;
                                ;;									  ;;
                                ;;  DESCRIPTION							     ;;
                                ;;      Resets Intellivoice, determines if it is actually there, and	;;
                                ;;      then initializes the IV structure.				  ;;
                                ;; ------------------------------------------------------------------------ ;;
                                ;;		   Copyright (c) 2002, Joseph Zbiciak		     ;;
                                ;; ======================================================================== ;;

0x6B42                          IV_INIT     PROC
6B42   02B8 0400                	    MVII    #$0400, R0	  ;
6B44   0240 0081                	    MVO     R0,     $0081       ; Reset the Intellivoice

6B46   0280 0081                	    MVI     $0081,  R0	  ; \
6B48   0054                     	    RLC     R0,     2	   ;  |-- See if we detect Intellivoice
6B49   0202 000A                	    BOV     @@no_ivoice	 ; /    once we've reset it.

6B4B   01C0                     	    CLRR    R0		  ; 
6B4C   0240 033D                	    MVO     R0,     IV.FPTR     ; No data for FIFO
6B4E   0240 033E                	    MVO     R0,     IV.PPTR     ; No phrase being spoken
6B50   0240 012E                	    MVO     R0,     IV.QH       ; Clear our queue
6B52   0240 012F                	    MVO     R0,     IV.QT       ; Clear our queue
6B54   00AF                     	    JR      R5		  ; Done!

0x6B55                          @@no_ivoice:
6B55   01C0                     	    CLRR    R0
6B56   0240 033D                	    MVO     R0,     IV.FPTR     ; No data for FIFO
6B58   0240 033E                	    MVO     R0,     IV.PPTR     ; No phrase being spoken
6B5A   0010                     	    DECR    R0
6B5B   0240 012E                	    MVO     R0,     IV.QH       ; Set queue to -1 ("No Intellivoice")
6B5D   0240 012F                	    MVO     R0,     IV.QT       ; Set queue to -1 ("No Intellivoice")
                                ;	    JR      R5		 ; Done!
6B5F   0220 0B07                	    B       _wait	       ; Special for IntyBASIC!
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_ISR      Interrupt service routine to feed Intellivoice	  ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      15-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_ISR						       ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0, R1, R4 trashed.						 ;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      Call this from your main interrupt service routine.		 ;;
                                ;; ------------------------------------------------------------------------ ;;
                                ;;		   Copyright (c) 2002, Joseph Zbiciak		     ;;
                                ;; ======================================================================== ;;
0x6B61                          IV_ISR      PROC
                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  Check for Intellivoice.  Leave if none present.	     ;;
                                	    ;; ------------------------------------------------------------ ;;
6B61   0281 012F                	    MVI     IV.QT,  R1	  ; Get queue tail
6B63   0045                     	    SWAP    R1,     2
6B64   0203 0001                	    BPL     @@ok		; Bit 7 set? If yes: No Intellivoice
0x6B66                          @@ald_busy:
6B66   00AF                     @@leave     JR      R5		  ; Exit if no Intellivoice.

                                     
                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  Check to see if we pump samples into the FIFO.
                                	    ;; ------------------------------------------------------------ ;;
6B67   0284 033D                @@ok:       MVI     IV.FPTR, R4	 ; Get FIFO data pointer
6B69   00A4                     	    TSTR    R4		  ; is it zero?
6B6A   0204 0015                	    BEQ     @@no_fifodata       ; Yes:  No data for FIFO.
0x6B6C                          @@fifo_fill:
6B6C   0280 0081                	    MVI     $0081,  R0	  ; Read speech FIFO ready bit
6B6E   0058                     	    SLLC    R0,     1	   ; 
6B6F   0201 0010                	    BC      @@fifo_busy     

6B71   02A0                     	    MVI@    R4,     R0	  ; Get next word
6B72   0240 0081                	    MVO     R0,     $0081       ; write it to the FIFO

6B74   0280 0130                	    MVI     IV.FLEN, R0	 ;\
6B76   0010                     	    DECR    R0		  ; |-- Decrement our FIFO'd data length
6B77   0240 0130                	    MVO     R0,     IV.FLEN     ;/
6B79   0204 0004                	    BEQ     @@last_fifo	 ; If zero, we're done w/ FIFO
6B7B   0244 033D                	    MVO     R4,     IV.FPTR     ; Otherwise, save new pointer
6B7D   0220 0012                	    B       @@fifo_fill	 ; ...and keep trying to load FIFO

6B7F   0240 033D                @@last_fifo MVO     R0,     IV.FPTR     ; done with FIFO loading.
                                					; fall into ALD processing.


                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  Try to do an Address Load.  We do this in two settings:     ;;
                                	    ;;   -- We have no FIFO data to load.			   ;;
                                	    ;;   -- We've loaded as much FIFO data as we can, but we	;;
                                	    ;;      might have an address load command to send for it.      ;;
                                	    ;; ------------------------------------------------------------ ;;
0x6B81                          @@fifo_busy:
0x6B81                          @@no_fifodata:
6B81   0280 0080                	    MVI     $0080,  R0	  ; Read LRQ bit from ALD register
6B83   0058                     	    SLLC    R0,     1
6B84   0229 001F                	    BNC     @@ald_busy	  ; LRQ is low, meaning we can't ALD.
                                					; So, leave.

                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  We can do an address load (ALD) on the SP0256.  Give FIFO   ;;
                                	    ;;  driven ALDs priority, since we already started the FIFO     ;;
                                	    ;;  load.  The "need ALD" bit is stored in bit 6 of IV.QT.      ;;
                                	    ;; ------------------------------------------------------------ ;;
6B86   03B9 0040                	    ANDI    #$40,   R1	  ; Is "Need FIFO ALD" bit set?
6B88   0204 0008                	    BEQ     @@no_fifo_ald
6B8A   03C1 012F                	    XOR     IV.QT,  R1	  ;\__ Clear the "Need FIFO ALD" bit.
6B8C   0241 012F                	    MVO     R1,     IV.QT       ;/
6B8E   01C9                     	    CLRR    R1
6B8F   0241 0080                	    MVO     R1,     $80	 ; Load a 0 into ALD (trigger FIFO rd.)
6B91   00AF                     	    JR      R5		  ; done!

                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  We don't need to ALD on behalf of the FIFO.  So, we grab    ;;
                                	    ;;  the next thing off our phrase list.			 ;;
                                	    ;; ------------------------------------------------------------ ;;
0x6B92                          @@no_fifo_ald:
6B92   0284 033E                	    MVI     IV.PPTR, R4	 ; Get phrase pointer.
6B94   00A4                     	    TSTR    R4		  ; Is it zero?
6B95   0204 0006                	    BEQ     @@next_phrase       ; Yes:  Get next phrase from queue.

6B97   02A0                     	    MVI@    R4,     R0
6B98   0080                     	    TSTR    R0		  ; Is it end of phrase?
6B99   020C 001D                	    BNEQ    @@process_phrase    ; !=0:  Go do it.

6B9B   0240 033E                	    MVO     R0,     IV.PPTR     ; 
0x6B9D                          @@next_phrase:
6B9D   0281 012F                	    MVI     IV.QT,  R1	  ; reload queue tail (was trashed above)
6B9F   0088                     	    MOVR    R1,     R0	  ; copy QT to R0 so we can increment it
6BA0   03B9 0007                	    ANDI    #$7,    R1	  ; Mask away flags in queue head
6BA2   0341 012E                	    CMP     IV.QH,  R1	  ; Is it same as queue tail?
6BA4   0224 003F                	    BEQ     @@leave	     ; Yes:  No more speech for now.

6BA6   0008                     	    INCR    R0
6BA7   03B8 00F7                	    ANDI    #$F7,   R0	  ; mask away the possible 'carry'
6BA9   0240 012F                	    MVO     R0,     IV.QT       ; save updated queue tail

6BAB   02F9 0335                	    ADDI    #IV.Q,  R1	  ; Index into queue
6BAD   028C                     	    MVI@    R1,     R4	  ; get next value from queue
6BAE   037C 002B                	    CMPI    #43,    R4	  ; Is it a RESROM or Phrase?
6BB0   0209 0003                	    BNC     @@play_resrom_r4
0x6BB2                          @@new_phrase:
                                ;	    ADDI    #IV_PHRASE_TBL - 43, R4 ; Index into phrase table
                                ;	    MVI@    R4,     R4	  ; Read from phrase table
6BB2   0244 033E                	    MVO     R4,     IV.PPTR
6BB4   00AF                     	    JR      R5		  ; we'll get to this phrase next time.

0x6BB5                          @@play_resrom_r4:
6BB5   0244 0080                	    MVO     R4,     $0080       ; Just ALD it
6BB7   00AF                     	    JR      R5		  ; and leave.

                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  We're in the middle of a phrase, so continue interpreting.  ;;
                                	    ;; ------------------------------------------------------------ ;;
0x6BB8                          @@process_phrase:
                                	    
6BB8   0244 033E                	    MVO     R4,     IV.PPTR     ; save new phrase pointer
6BBA   0378 002B                	    CMPI    #43,    R0	  ; Is it a RESROM cue?
6BBC   0201 0003                	    BC      @@play_fifo	 ; Just ALD it and leave.
0x6BBE                          @@play_resrom_r0
6BBE   0240 0080                	    MVO     R0,     $0080       ; Just ALD it
6BC0   00AF                     	    JR      R5		  ; and leave.
0x6BC1                          @@play_fifo:
6BC1   0281 033D                	    MVI     IV.FPTR,R1	  ; Make sure not to stomp existing FIFO
6BC3   0089                     	    TSTR    R1		  ; data.
6BC4   0204 0004                	    BEQ     @@new_fifo_ok
6BC6   0014                     	    DECR    R4		  ; Oops, FIFO data still playing,
6BC7   0244 033E                	    MVO     R4,     IV.PPTR     ; so rewind.
6BC9   00AF                     	    JR      R5		  ; and leave.

0x6BCA                          @@new_fifo_ok:
6BCA   0084                     	    MOVR    R0,     R4	  ;
6BCB   02A0                     	    MVI@    R4,     R0	  ; Get chunk length
6BCC   0240 0130                	    MVO     R0,     IV.FLEN     ; Init FIFO chunk length
6BCE   0244 033D                	    MVO     R4,     IV.FPTR     ; Init FIFO pointer
6BD0   0280 012F                	    MVI     IV.QT,  R0	  ;\
6BD2   03F8 0040                	    XORI    #$40,   R0	  ; |- Set "Need ALD" bit in QT
6BD4   0240 012F                	    MVO     R0,     IV.QT       ;/

                                  IF 1      ; debug code		;\
6BD6   03B8 0040                	    ANDI    #$40,   R0	  ; |   Debug code:  We should only
6BD8   020C 0001                	    BNEQ    @@qtok	      ; |-- be here if "Need FIFO ALD" 
6BDA   0000                     	    HLT     ;BUG!!	      ; |   was already clear.	 
0x6BDB                          @@qtok				  ;/    
                                  ENDI
6BDB   00AF                     	    JR      R5		  ; leave.

                                	    ENDP


                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_PLAY     Play a voice sample sequence.			   ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      15-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_PLAY						      ;;
                                ;;      R5      Invocation record, followed by return address.	      ;;
                                ;;		  1 DECLE    Phrase number to play.		       ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_PLAY.1						    ;;
                                ;;      R0      Address of phrase to play.				  ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0, R1  trashed						     ;;
                                ;;      Z==0    if item not successfully queued.			    ;;
                                ;;      Z==1    if successfully queued.				     ;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      This code will drop phrases if the queue is full.		   ;;
                                ;;      Phrase numbers 1..42 are RESROM samples.  43..255 will index	;;
                                ;;      into the user-supplied IV_PHRASE_TBL.  43 will refer to the	 ;;
                                ;;      first entry, 44 to the second, and so on.  Phrase 0 is undefined.   ;;
                                ;;									  ;;
                                ;; ------------------------------------------------------------------------ ;;
                                ;;		   Copyright (c) 2002, Joseph Zbiciak		     ;;
                                ;; ======================================================================== ;;
0x6BDC                          IV_PLAY     PROC
6BDC   02A8                     	    MVI@    R5,     R0

0x6BDD                          @@1:	; alternate entry point
6BDD   0281 012F                	    MVI     IV.QT,  R1	  ; Get queue tail
6BDF   0045                     	    SWAP    R1,     2	   ;\___ Leave if "no Intellivoice"
6BE0   020B 0013                	    BMI     @@leave	     ;/    bit it set.
0x6BE2                          @@ok:       
6BE2   0011                     	    DECR    R1		  ;\
6BE3   03B9 0007                	    ANDI    #$7,    R1	  ; |-- See if we still have room
6BE5   0341 012E                	    CMP     IV.QH,  R1	  ;/
6BE7   0204 000C                	    BEQ     @@leave	     ; Leave if we're full

6BE9   0281 012E                @@2:	MVI     IV.QH,  R1	  ; Get our queue head pointer
6BEB   0271                     	    PSHR    R1		  ;\
6BEC   0009                     	    INCR    R1		  ; |
6BED   03B9 00F7                	    ANDI    #$F7,   R1	  ; |-- Increment it, removing
6BEF   0241 012E                	    MVO     R1,     IV.QH       ; |   carry but preserving flags.
6BF1   02B1                     	    PULR    R1		  ;/

6BF2   02F9 0335                	    ADDI    #IV.Q,  R1	  ;\__ Store phrase to queue
6BF4   0248                     	    MVO@    R0,     R1	  ;/

6BF5   00AF                     @@leave:    JR      R5		  ; Leave.
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_PLAYW    Play a voice sample sequence.  Wait for queue room.     ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      15-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_PLAY						      ;;
                                ;;      R5      Invocation record, followed by return address.	      ;;
                                ;;		  1 DECLE    Phrase number to play.		       ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_PLAY.1						    ;;
                                ;;      R0      Address of phrase to play.				  ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0, R1  trashed						     ;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      This code will wait for a queue slot to open if queue is full.      ;;
                                ;;      Phrase numbers 1..42 are RESROM samples.  43..255 will index	;;
                                ;;      into the user-supplied IV_PHRASE_TBL.  43 will refer to the	 ;;
                                ;;      first entry, 44 to the second, and so on.  Phrase 0 is undefined.   ;;
                                ;;									  ;;
                                ;; ------------------------------------------------------------------------ ;;
                                ;;		   Copyright (c) 2002, Joseph Zbiciak		     ;;
                                ;; ======================================================================== ;;
0x6BF6                          IV_PLAYW    PROC
6BF6   02A8                     	    MVI@    R5,     R0

0x6BF7                          @@1:	; alternate entry point
6BF7   0281 012F                	    MVI     IV.QT,  R1	  ; Get queue tail
6BF9   0045                     	    SWAP    R1,     2	   ;\___ Leave if "no Intellivoice"
6BFA   022B 0006                	    BMI     IV_PLAY.leave       ;/    bit it set.
0x6BFC                          @@ok:       
6BFC   0011                     	    DECR    R1		  ;\
6BFD   03B9 0007                	    ANDI    #$7,    R1	  ; |-- See if we still have room
6BFF   0341 012E                	    CMP     IV.QH,  R1	  ;/
6C01   0224 000B                	    BEQ     @@1		 ; wait for room
6C03   0220 001B                	    B       IV_PLAY.2

                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_HUSH     Flush the speech queue, and hush the Intellivoice.      ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      02-Feb-2018 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_HUSH						      ;;
                                ;;      None.							       ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0 trashed.							 ;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      Returns via IV_WAIT.						;;
                                ;;									  ;;
                                ;; ======================================================================== ;;
0x6C05                          IV_HUSH:    PROC
6C05   0280 012E                	    MVI     IV.QH,  R0
6C07   0044                     	    SWAP    R0,     2
6C08   020B 0028                	    BMI     IV_WAIT.leave

6C0A   0003                     	    DIS
                                	    ;; We can't stop a phrase segment that's being FIFOed down.
                                	    ;; We need to remember if we've committed to pushing ALD.
                                	    ;; We _can_ stop new phrase segments from going down, and _can_
                                	    ;; stop new phrases from being started.

                                	    ;; Set head pointer to indicate we've inserted one item.
6C0B   0280 012E                	    MVI     IV.QH,  R0  ; Re-read, as an interrupt may have occurred
6C0D   03B8 00F0                	    ANDI    #$F0,   R0
6C0F   0008                     	    INCR    R0
6C10   0240 012E                	    MVO     R0,     IV.QH

                                	    ;; Reset tail pointer, keeping "need ALD" bit and other flags.
6C12   0280 012F                	    MVI     IV.QT,  R0
6C14   03B8 00F0                	    ANDI    #$F0,   R0
6C16   0240 012F                	    MVO     R0,     IV.QT

                                	    ;; Reset the phrase pointer, to stop a long phrase.
6C18   01C0                     	    CLRR    R0
6C19   0240 033E                	    MVO     R0,     IV.PPTR

                                	    ;; Queue a PA1 in the queue.  Since we're can't guarantee the user
                                	    ;; has included resrom.asm, let's just use the raw number (5).
6C1B   02B8 0005                	    MVII    #5,     R0
6C1D   0240 0335                	    MVO     R0,     IV.Q

                                	    ;; Re-enable interrupts and wait for Intellivoice to shut up.
                                	    ;;
                                	    ;; We can't just jump to IV_WAIT.q_loop, as we need to reload
                                	    ;; IV.QH into R0, and I'm really committed to only using R0.
                                ;	   JE      IV_WAIT
6C1F   0002                     	    EIS
                                	    ; fallthrough into IV_WAIT
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_WAIT     Wait for voice queue to empty.			  ;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      15-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_WAIT						      ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;      R0      trashed.						    ;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      This waits until the Intellivoice is nearly completely quiescent.   ;;
                                ;;      Some voice data may still be spoken from the last triggered	 ;;
                                ;;      phrase.  To truly wait for *that* to be spoken, speak a 'pause'     ;;
                                ;;      (eg. RESROM.pa1) and then call IV_WAIT.			     ;;
                                ;; ------------------------------------------------------------------------ ;;
                                ;;		   Copyright (c) 2002, Joseph Zbiciak		     ;;
                                ;; ======================================================================== ;;
0x6C20                          IV_WAIT     PROC
6C20   0280 012E                	    MVI     IV.QH,  R0
6C22   0378 0080                	    CMPI    #$80, R0	    ; test bit 7, leave if set.
6C24   0201 000C                	    BC      @@leave

                                	    ; Wait for queue to drain.
6C26   0340 012F                @@q_loop:   CMP     IV.QT,  R0
6C28   022C 0003                	    BNEQ    @@q_loop

                                	    ; Wait for FIFO and LRQ to say ready.
6C2A   0280 0081                @@s_loop:   MVI     $81,    R0	  ; Read FIFO status.  0 == ready.
6C2C   0018                     	    COMR    R0
6C2D   0380 0080                	    AND     $80,    R0	  ; Merge w/ ALD status.  1 == ready
6C2F   0080                     	    TSTR    R0
6C30   0223 0007                	    BPL     @@s_loop	    ; if bit 15 == 0, not ready.
                                	    
6C32   00AF                     @@leave:    JR      R5
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  End of File:  ivoice.asm						;;
                                ;; ======================================================================== ;;

                                ;* ======================================================================== *;
                                ;*  These routines are placed into the public domain by their author.  All  *;
                                ;*  copyright rights are hereby relinquished on the routines and data in    *;
                                ;*  this file.  -- Joseph Zbiciak, 2008				     *;
                                ;* ======================================================================== *;

                                ;; ======================================================================== ;;
                                ;;  NAME								    ;;
                                ;;      IV_SAYNUM16 Say a 16-bit unsigned number using RESROM digits	;;
                                ;;									  ;;
                                ;;  AUTHOR								  ;;
                                ;;      Joseph Zbiciak <intvnut AT gmail.com>			       ;;
                                ;;									  ;;
                                ;;  REVISION HISTORY							;;
                                ;;      16-Sep-2002 Initial revision . . . . . . . . . . .  J. Zbiciak      ;;
                                ;;									  ;;
                                ;;  INPUTS for IV_SAYNUM16						  ;;
                                ;;      R0      Number to "speak"					   ;;
                                ;;      R5      Return address					      ;;
                                ;;									  ;;
                                ;;  OUTPUTS								 ;;
                                ;;									  ;;
                                ;;  DESCRIPTION							     ;;
                                ;;      "Says" a 16-bit number using IV_PLAYW to queue up the phrase.       ;;
                                ;;      Because the number may be built from several segments, it could     ;;
                                ;;      easily eat up the queue.  I believe the longest number will take    ;;
                                ;;      7 queue entries -- that is, fill the queue.  Thus, this code	;;
                                ;;      could block, waiting for slots in the queue.			;;
                                ;; ======================================================================== ;;

0x6C33                          IV_SAYNUM16 PROC
6C33   0275                     	    PSHR    R5

6C34   0080                     	    TSTR    R0
6C35   0204 0045                	    BEQ     @@zero	  ; Special case:  Just say "zero"

                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  First, try to pull off 'thousands'.  We call ourselves      ;;
                                	    ;;  recursively to play the the number of thousands.	    ;;
                                	    ;; ------------------------------------------------------------ ;;
6C37   01C9                     	    CLRR    R1
6C38   0009                     @@thloop:   INCR    R1
6C39   0338 03E8                	    SUBI    #1000,  R0
6C3B   0221 0004                	    BC      @@thloop

6C3D   02F8 03E8                	    ADDI    #1000,  R0
6C3F   0270                     	    PSHR    R0
6C40   0011                     	    DECR    R1
6C41   0204 0007                	    BEQ     @@no_thousand

6C43   0004 016C 0063           	    CALL    IV_SAYNUM16.recurse

6C46   0004 0168 03F6           	    CALL    IV_PLAYW
6C49   0024                     	    DECLE   36  ; THOUSAND
                                	    
0x6C4A                          @@no_thousand
6C4A   02B1                     	    PULR    R1

                                	    ;; ------------------------------------------------------------ ;;
                                	    ;;  Now try to play hundreds.				   ;;
                                	    ;; ------------------------------------------------------------ ;;
6C4B   02B8 0006                	    MVII    #7-1, R0    ; ZERO
6C4D   0379 0064                	    CMPI    #100,   R1
6C4F   0209 0013                	    BNC     @@no_hundred

6C51   0008                     @@hloop:    INCR    R0
6C52   0339 0064                	    SUBI    #100,   R1
6C54   0221 0004                	    BC      @@hloop
6C56   02F9 0064                	    ADDI    #100,   R1

6C58   0271                     	    PSHR    R1

6C59   0004 0168 03F7           	    CALL    IV_PLAYW.1

6C5C   0004 0168 03F6           	    CALL    IV_PLAYW
6C5F   0023                     	    DECLE   35  ; HUNDRED

6C60   02B1                     	    PULR    R1
6C61   0200 0001                	    B       @@notrecurse    ; skip "PSHR R5"
6C63   0275                     @@recurse:  PSHR    R5	      ; recursive entry point for 'thousand'

0x6C64                          @@no_hundred:
0x6C64                          @@notrecurse:
6C64   0088                     	    MOVR    R1,     R0
6C65   0204 001A                	    BEQ     @@leave

6C67   0339 0014                	    SUBI    #20,    R1
6C69   0209 0011                	    BNC     @@teens

6C6B   02B8 001A                	    MVII    #27-1, R0   ; TWENTY
6C6D   0008                     @@tyloop    INCR    R0
6C6E   0339 000A                	    SUBI    #10,    R1
6C70   0221 0004                	    BC      @@tyloop
6C72   02F9 000A                	    ADDI    #10,    R1

6C74   0271                     	    PSHR    R1
6C75   0004 0168 03F7           	    CALL    IV_PLAYW.1

6C78   02B0                     	    PULR    R0
6C79   0080                     	    TSTR    R0
6C7A   0204 0005                	    BEQ     @@leave

0x6C7C                          @@teens:
6C7C   02F8 0007                @@zero:     ADDI    #7, R0  ; ZERO

6C7E   0004 0168 03F7           	    CALL    IV_PLAYW.1

6C81   02B7                     @@leave     PULR    PC
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  End of File:  saynum16.asm					      ;;
                                ;; ======================================================================== ;;

0x6B42                          IV_INIT_and_wait:     EQU IV_INIT

                                    ELSE

                                IV_INIT_and_wait:     EQU _wait	; No voice init; just WAIT.

                                    ENDI

                                	IF intybasic_flash

                                ;; ======================================================================== ;;
                                ;;  JLP "Save Game" support						 ;;
                                ;; ======================================================================== ;;
                                JF.first    EQU     $8023
                                JF.last     EQU     $8024
                                JF.addr     EQU     $8025
                                JF.row      EQU     $8026
                                		   
                                JF.wrcmd    EQU     $802D
                                JF.rdcmd    EQU     $802E
                                JF.ercmd    EQU     $802F
                                JF.wrkey    EQU     $C0DE
                                JF.rdkey    EQU     $DEC0
                                JF.erkey    EQU     $BEEF

                                JF.write:   DECLE   JF.wrcmd,   JF.wrkey    ; Copy JLP RAM to flash row  
                                JF.read:    DECLE   JF.rdcmd,   JF.rdkey    ; Copy flash row to JLP RAM  
                                JF.erase:   DECLE   JF.ercmd,   JF.erkey    ; Erase flash sector 

                                ;; ======================================================================== ;;
                                ;;  JF.INIT	 Copy JLP save-game support routine to System RAM	;;
                                ;; ======================================================================== ;;
                                JF.INIT     PROC
                                	    PSHR    R5	    
                                	    MVII    #@@__code,  R5
                                	    MVII    #JF.SYSRAM, R4
                                	    REPEAT  5       
                                	    MVI@    R5,	 R0      ; \_ Copy code fragment to System RAM
                                	    MVO@    R0,	 R4      ; /
                                	    ENDR
                                	    PULR    PC

                                	    ;; === start of code that will run from RAM
                                @@__code:   MVO@    R0,	 R1      ; JF.SYSRAM + 0: initiate command
                                	    ADD@    R1,	 PC      ; JF.SYSRAM + 1: Wait for JLP to return
                                	    JR      R5		  ; JF.SYSRAM + 2:
                                	    MVO@    R2,	 R2      ; JF.SYSRAM + 3: \__ simple ISR
                                	    JR      R5		  ; JF.SYSRAM + 4: /
                                	    ;; === end of code that will run from RAM
                                	    ENDP

                                ;; ======================================================================== ;;
                                ;;  JF.CMD	  Issue a JLP Flash command			       ;;
                                ;;									  ;;
                                ;;  INPUT								   ;;
                                ;;      R0  Slot number to operate on				       ;;
                                ;;      R1  Address to copy to/from in JLP RAM			      ;;
                                ;;      @R5 Command to invoke:					      ;;
                                ;;									  ;;
                                ;;	      JF.write -- Copy JLP RAM to Flash			   ;;
                                ;;	      JF.read  -- Copy Flash to JLP RAM			   ;;
                                ;;	      JF.erase -- Erase flash sector			      ;;
                                ;;									  ;;
                                ;;  OUTPUT								  ;;
                                ;;      R0 - R4 not modified.  (Saved and restored across call)	     ;;
                                ;;      JLP command executed						;;
                                ;;									  ;;
                                ;;  NOTES								   ;;
                                ;;      This code requires two short routines in the console's System RAM.  ;;
                                ;;      It also requires that the system stack reside in System RAM.	;;
                                ;;      Because an interrupt may occur during the code's execution, there   ;;
                                ;;      must be sufficient stack space to service the interrupt (8 words).  ;;
                                ;;									  ;;
                                ;;      The code also relies on the fact that the EXEC ISR dispatch does    ;;
                                ;;      not modify R2.  This allows us to initialize R2 for the ISR ahead   ;;
                                ;;      of time, rather than in the ISR.				    ;;
                                ;; ======================================================================== ;;
                                JF.CMD      PROC

                                	    MVO     R4,	 JF.SV.R4    ; \
                                	    MVII    #JF.SV.R0,  R4	  ;  |
                                	    MVO@    R0,	 R4	  ;  |- Save registers, but not on
                                	    MVO@    R1,	 R4	  ;  |  the stack.  (limit stack use)
                                	    MVO@    R2,	 R4	  ; /

                                	    MVI@    R5,	 R4	  ; Get command to invoke

                                	    MVO     R5,	 JF.SV.R5    ; save return address

                                	    DIS
                                	    MVO     R1,	 JF.addr     ; \_ Save SG arguments in JLP
                                	    MVO     R0,	 JF.row      ; /
                                					  
                                	    MVI@    R4,	 R1	  ; Get command address
                                	    MVI@    R4,	 R0	  ; Get unlock word
                                					  
                                	    MVII    #$100,      R4	  ; \
                                	    SDBD			    ;  |_ Save old ISR in save area
                                	    MVI@    R4,	 R2	  ;  |
                                	    MVO     R2,	 JF.SV.ISR   ; /
                                					  
                                	    MVII    #JF.SYSRAM + 3, R2      ; \
                                	    MVO     R2,	 $100	;  |_ Set up new ISR in RAM
                                	    SWAP    R2		      ;  |
                                	    MVO     R2,	 $101	; / 
                                					  
                                	    MVII    #$20,       R2	  ; Address of STIC handshake
                                	    JSRE    R5,  JF.SYSRAM	  ; Invoke the command
                                					  
                                	    MVI     JF.SV.ISR,  R2	  ; \
                                	    MVO     R2,	 $100	;  |_ Restore old ISR 
                                	    SWAP    R2		      ;  |
                                	    MVO     R2,	 $101	; /
                                					  
                                	    MVII    #JF.SV.R0,  R5	  ; \
                                	    MVI@    R5,	 R0	  ;  |
                                	    MVI@    R5,	 R1	  ;  |- Restore registers
                                	    MVI@    R5,	 R2	  ;  |
                                	    MVI@    R5,	 R4	  ; /
                                	    MVI@    R5,	 PC	  ; Return

                                	    ENDP


                                	ENDI

