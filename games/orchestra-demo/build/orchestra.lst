6B39   03D4 0156 0052 0131          DECLE   $03D4, $0156, $0052, $0131, $0008, $03B0, $01BE, $0172
6B3D   0008 03B0 01BE 0172 
6B41   0000                         DECLE   $0000
0x6B42                          _ZZ.end:  ; 25 decles

