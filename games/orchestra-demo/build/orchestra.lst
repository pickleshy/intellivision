0x348                           _mobs:      RMB 3*8     ; MOB buffer

0x100                           SCRATCH:    ORG $100,$100,"-RWBN"
                                	;
                                	; 8-bits variables
                                	;
0x100                           ISRVEC:     RMB 2       ; Pointer to ISR vector (required by Intellivision ROM)
0x102                           _int:       RMB 1       ; Signals interrupt received
0x103                           _ntsc:      RMB 1       ; bit 0 = 1=NTSC, 0=PAL. Bit 1 = 1=ECS detected.
0x104                           _rand:      RMB 1       ; Pseudo-random value
0x105                           _gram_target:   RMB 1   ; Contains GRAM card number
0x106                           _gram_total:    RMB 1   ; Contains total GRAM cards for definition
0x107                           _gram2_target:  RMB 1   ; Contains GRAM card number
0x108                           _gram2_total:   RMB 1   ; Contains total GRAM cards for definition
0x109                           _mode_select:   RMB 1   ; Graphics mode selection
0x10A                           _border_color:  RMB 1   ; Border color
0x10B                           _border_mask:   RMB 1   ; Border mask
                                    IF intybasic_keypad
0x10C                           _cnt1_p0:   RMB 1       ; Debouncing 1
0x10D                           _cnt1_p1:   RMB 1       ; Debouncing 2
0x10E                           _cnt1_key:  RMB 1       ; Currently pressed key
0x10F                           _cnt2_p0:   RMB 1       ; Debouncing 1
0x110                           _cnt2_p1:   RMB 1       ; Debouncing 2
0x111                           _cnt2_key:  RMB 1       ; Currently pressed key
                                    ENDI
                                    IF intybasic_scroll
                                _scroll_x:  RMB 1       ; Scroll X offset
                                _scroll_y:  RMB 1       ; Scroll Y offset
                                _scroll_d:  RMB 1       ; Scroll direction
                                    ENDI
                                    IF intybasic_music
0x112                           _music_start:	RMB 2	; Start of music

0x114                           _music_mode: RMB 1      ; Music mode (0= Not using PSG, 2= Simple, 4= Full, add 1 if using noise channel for drums)
0x115                           _music_frame: RMB 1     ; Music frame (for 50 hz fixed)
0x116                           _music_tc:  RMB 1       ; Time counter
0x117                           _music_t:   RMB 1       ; Time base
0x118                           _music_i1:  RMB 1       ; Instrument 1 
0x119                           _music_s1:  RMB 1       ; Sample pointer 1
0x11A                           _music_n1:  RMB 1       ; Note 1
0x11B                           _music_i2:  RMB 1       ; Instrument 2
0x11C                           _music_s2:  RMB 1       ; Sample pointer 2
0x11D                           _music_n2:  RMB 1       ; Note 2
0x11E                           _music_i3:  RMB 1       ; Instrument 3
0x11F                           _music_s3:  RMB 1       ; Sample pointer 3
0x120                           _music_n3:  RMB 1       ; Note 3
0x121                           _music_s4:  RMB 1       ; Sample pointer 4
0x122                           _music_n4:  RMB 1       ; Note 4 (really it's drum)

0x123                           _music_freq10:	RMB 1   ; Low byte frequency A
0x124                           _music_freq20:	RMB 1   ; Low byte frequency B
0x125                           _music_freq30:	RMB 1   ; Low byte frequency C
0x126                           _music_freq11:	RMB 1   ; High byte frequency A
0x127                           _music_freq21:	RMB 1   ; High byte frequency B
0x128                           _music_freq31:	RMB 1   ; High byte frequency C
0x129                           _music_mix:	RMB 1   ; Mixer
0x12A                           _music_noise:	RMB 1   ; Noise
0x12B                           _music_vol1:	RMB 1   ; Volume A
0x12C                           _music_vol2:	RMB 1   ; Volume B
0x12D                           _music_vol3:	RMB 1   ; Volume C
                                    ENDI
                                    IF intybasic_music_ecs
                                _music_i5:  RMB 1       ; Instrument 5
                                _music_s5:  RMB 1       ; Sample pointer 5
                                _music_n5:  RMB 1       ; Note 5
                                _music_i6:  RMB 1       ; Instrument 6
                                _music_s6:  RMB 1       ; Sample pointer 6
                                _music_n6:  RMB 1       ; Note 6
                                _music_i7:  RMB 1       ; Instrument 7
                                _music_s7:  RMB 1       ; Sample pointer 7
                                _music_n7:  RMB 1       ; Note 7
                                _music_s8:  RMB 1       ; Sample pointer 8
                                _music_n8:  RMB 1       ; Note 8 (really it's drum)

                                _music2_freq10:	RMB 1   ; Low byte frequency A
                                _music2_freq20:	RMB 1   ; Low byte frequency B
                                _music2_freq30:	RMB 1   ; Low byte frequency C
                                _music2_freq11:	RMB 1   ; High byte frequency A
                                _music2_freq21:	RMB 1   ; High byte frequency B
                                _music2_freq31:	RMB 1   ; High byte frequency C
                                _music2_mix:	RMB 1   ; Mixer
                                _music2_noise:	RMB 1   ; Noise
                                _music2_vol1:	RMB 1   ; Volume A
                                _music2_vol2:	RMB 1   ; Volume B
                                _music2_vol3:	RMB 1   ; Volume C
                                    ENDI
                                    IF intybasic_music_volume
                                _music_vol:	RMB 1	; Global music volume
                                    ENDI
                                    IF intybasic_voice
0x12E                           IV.QH:     RMB 1    ; IV_xxx	8-bit	   Voice queue head
0x12F                           IV.QT:     RMB 1    ; IV_xxx	8-bit	   Voice queue tail
0x130                           IV.FLEN:   RMB 1    ; IV_xxx	8-bit	   Length of FIFO data
                                    ENDI

